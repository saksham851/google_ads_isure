<div class="row">
    <div class="col-12">
        <div class="card table-card mt-3">
            <div class="card-header border-bottom py-3">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div>
                        <h5 class="mb-0 fw-bold">Conversion Logs</h5>
                        <p class="text-muted mb-0" style="font-size: 13px;">Recent offline conversions pushed to Google Ads.</p>
                    </div>
                    
                    <form action="/logs" method="GET" class="d-flex align-items-center gap-2 flex-wrap">
                        <!-- Search term -->
                        <div class="input-group input-group-sm" style="width: 250px;">
                            <span class="input-group-text bg-white border-end-0"><i class="ti ti-search text-muted"></i></span>
                            <input type="text" name="search" class="form-control ps-0 border-start-0" placeholder="Search GCLID/Email..." value="<%= typeof search !== 'undefined' ? search : '' %>" style="border-radius: 0 8px 8px 0;">
                        </div>

                        <!-- Agency Filter (Only for superadmin) -->
                        <% if (typeof user !== 'undefined' && user.role === 'superadmin') { %>
                            <select name="locationId" class="form-select form-select-sm" style="width: 200px; border-radius: 8px;">
                                <option value="">— All Sub-accounts —</option>
                                <% agencies.forEach(ag => { %>
                                    <option value="<%= ag.locationId %>" <%= locationId === ag.locationId ? 'selected' : '' %>><%= ag.agencyName %></option>
                                <% }) %>
                            </select>
                        <% } %>

                        <!-- Days Filter -->
                        <select name="days" class="form-select form-select-sm" style="width: 140px; border-radius: 8px;">
                            <option value="all" <%= days === 'all' ? 'selected' : '' %>>All Time</option>
                            <option value="7" <%= days === '7' ? 'selected' : '' %>>Last 7 Days</option>
                            <option value="30" <%= days === '30' ? 'selected' : '' %>>Last 30 Days</option>
                            <option value="90" <%= days === '90' ? 'selected' : '' %>>Last 90 Days</option>
                        </select>

                        <button type="submit" class="btn btn-sm btn-primary px-3" style="border-radius: 8px;">
                            <i class="ti ti-filter me-1"></i> Apply
                        </button>
                        
                        <% if (locationId || (days && days !== 'all') || (typeof search !== 'undefined' && search)) { %>
                            <a href="/logs" class="btn btn-sm btn-light border px-2" title="Reset Filters" style="border-radius: 8px;">
                                <i class="ti ti-rotate-clockwise"></i>
                            </a>
                        <% } %>
                    </form>
                </div>
            </div>
            <div class="card-body pt-3">
                <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                    <table class="table mb-0">
                        <thead style="position: sticky; top: 0; background: #fff; z-index: 1;">
                            <tr>
                                <th>Sub-account</th>
                                <th>Lead Email</th>
                                <th>GCLID</th>
                                <th>Action</th>
                                <th>Value</th>
                                <th>Status</th>
                                <th>Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% logs.forEach(log => { %>
                            <tr>
                                <td><span class="fw-bold text-dark"><%= log.agencyId ? log.agencyId.agencyName : 'Unknown' %></span></td>
                                <td><%= log.leadId ? log.leadId.email : 'N/A' %></td>
                                <td><code><%= (log.gclid || '').substring(0, 16) %>...</code></td>
                                <td><%= log.conversionAction || '—' %></td>
                                <td><%= log.conversionValue || 0 %></td>
                                <td>
                                    <% 
                                        var statusColor = log.status === 'success' ? '#1e8e3e' : (log.status === 'failed' ? '#c5221f' : '#b06000');
                                        var statusBg    = log.status === 'success' ? '#e6f4ea'  : (log.status === 'failed' ? '#fce8e6'  : '#fef9e7');
                                    %>
                                    <span style="background:<%= statusBg %>;color:<%= statusColor %>;border-radius:12px;padding:3px 10px;font-size:12px;font-weight:600;">
                                        <%= (log.status || 'unknown').toUpperCase() %>
                                    </span>
                                </td>
                                <td style="font-size: 13px; color: #70757a;"><%= new Date(log.createdAt).toLocaleString() %></td>
                            </tr>
                            <% }) %>
                            <% if (logs.length === 0) { %>
                                <tr>
                                    <td colspan="7" class="text-center py-5 text-muted">No conversion logs found.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <% if (totalPages > 1) { %>
                <div class="card-footer bg-white border-top py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="text-muted small">
                            Showing <%= logs.length %> of <%= totalLogs %> entries
                        </div>
                        <nav aria-label="Page navigation">
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                    <a class="page-link" href="/logs?page=<%= currentPage - 1 %>&locationId=<%= locationId %>&days=<%= days %>&search=<%= typeof search !== 'undefined' ? search : '' %>">
                                        <i class="ti ti-chevron-left"></i>
                                    </a>
                                </li>
                                
                                <% 
                                    let startPage = Math.max(1, currentPage - 2);
                                    let endPage = Math.min(totalPages, startPage + 4);
                                    if (endPage - startPage < 4) startPage = Math.max(1, endPage - 4);
                                %>

                                <% for(let i = startPage; i <= endPage; i++) { %>
                                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                        <a class="page-link" href="/logs?page=<%= i %>&locationId=<%= locationId %>&days=<%= days %>&search=<%= typeof search !== 'undefined' ? search : '' %>"><%= i %></a>
                                    </li>
                                <% } %>

                                <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                    <a class="page-link" href="/logs?page=<%= currentPage + 1 %>&locationId=<%= locationId %>&days=<%= days %>&search=<%= typeof search !== 'undefined' ? search : '' %>">
                                        <i class="ti ti-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
