<div class="row">
    <div class="col-12">
        <!-- Slim Audit Context Indicator -->
        <% if (typeof filteredByUserName !== 'undefined' && filteredByUserName) { %>
            <div class="d-flex align-items-center justify-content-between px-3 py-2 mb-3 bg-white border rounded shadow-sm border-start-4 border-warning">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-soft-warning p-2 rounded-circle">
                        <i class="ti ti-user text-warning h5 mb-0"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block" style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px;">User Webhook Stream</small>
                        <span class="fw-bold text-dark"><%= filteredByUserName %></span>
                    </div>
                </div>
                <a href="/webhooks-logs" class="btn btn-sm btn-outline-danger rounded-pill px-3" style="font-size: 11px;">
                    <i class="ti ti-x small"></i> Clear Audit Mode
                </a>
            </div>
        <% } %>

        <div class="card border-0 shadow-sm" style="border-radius: 12px;">
            <div class="card-header border-bottom bg-white py-3 px-4">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                    <div>
                        <h6 class="mb-1 fw-bold text-dark">Webhook Stream</h6>
                        <p class="text-muted mb-0 small">Real-time data synchronization logs from GoHighLevel.</p>
                    </div>
                    
                    <form action="/webhooks-logs" method="GET" class="d-flex align-items-center gap-2">
                        <div class="input-group input-group-sm border rounded-pill overflow-hidden px-2 bg-light" style="width: 220px;">
                            <span class="input-group-text bg-transparent border-0"><i class="ti ti-search text-muted small"></i></span>
                            <input type="text" name="search" class="form-control bg-transparent border-0 shadow-none ps-0" placeholder="Search events..." value="<%= typeof search !== 'undefined' ? search : '' %>">
                        </div>

                        <% if (typeof user !== 'undefined' && user.role === 'superadmin') { %>
                            <select name="locationId" class="form-select form-select-sm border rounded-pill px-3 shadow-none bg-light" style="width: 170px;">
                                <option value="">Global Stream</option>
                                <% agencies.forEach(ag => { %>
                                    <option value="<%= ag.locationId %>" <%= locationId === ag.locationId ? 'selected' : '' %>><%= ag.agencyName %></option>
                                <% }) %>
                            </select>
                        <% } %>

                        <select name="days" class="form-select form-select-sm border rounded-pill px-3 shadow-none bg-light" style="width: 110px;">
                            <option value="all" <%= days === 'all' ? 'selected' : '' %>>All Time</option>
                            <option value="7" <%= days === '7' ? 'selected' : '' %>>7d</option>
                            <option value="30" <%= days === '30' ? 'selected' : '' %>>30d</option>
                        </select>

                        <% if ((typeof search !== 'undefined' && search) || (typeof locationId !== 'undefined' && locationId) || (typeof days !== 'undefined' && days !== 'all')) { %>
                            <a href="/webhooks-logs" class="btn btn-light btn-sm rounded-pill px-3 fw-bold border">
                                <i class="ti ti-rotate-clockwise me-1"></i> Clear
                            </a>
                        <% } %>

                        <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4 shadow-sm">
                            Refresh
                        </button>
                    </form>
                </div>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" style="font-size: 13px;">
                        <thead class="bg-light">
                            <tr>
                                <th class="px-4 py-3 border-0 text-muted small text-uppercase" style="width: 100px;">Source</th>
                                <th class="py-3 border-0 text-muted small text-uppercase">Account Name</th>
                                <th class="py-3 border-0 text-muted small text-uppercase">Contact Reference</th>
                                <th class="py-3 border-0 text-muted small text-uppercase text-center">Status</th>
                                <th class="py-3 px-4 border-0 text-muted small text-uppercase text-end">Received At</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% logs.forEach(log => { %>
                            <tr class="transition-all webhook-row" style="cursor: pointer;" 
                                data-payload='<%= JSON.stringify(log.payload || {}) %>' 
                                data-source="<%= log.source || 'GHL' %>" 
                                data-time="<%= new Date(log.createdAt).toLocaleString() %>">
                                <td class="px-4 py-3">
                                    <span class="badge bg-soft-primary text-primary px-2 rounded-pill fw-bold" style="font-size: 10px;"><%= log.source || 'GHL' %></span>
                                </td>
                                <td>
                                    <span class="fw-bold text-dark d-block"><%= log.agencyName %></span>
                                    <code class="text-muted" style="font-size: 10px;">ID: <%= (log.locationId || 'unknown').substring(0,8) %>...</code>
                                </td>
                                <td>
                                    <div class="d-inline-flex align-items-center bg-light border rounded px-2 py-1" style="font-family: monospace; font-size: 11px;">
                                        <i class="ti ti-id me-1 opacity-50"></i>
                                        <%= (log.payload?.contact_id || log.payload?.id || 'unknown').substring(0,12) %>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <% if (log.status === 'success') { %>
                                        <span class="d-inline-flex align-items-center gap-1 text-success fw-bold" style="font-size: 11px;">
                                            <i class="ti ti-circle-check-filled"></i> PROCESSED
                                        </span>
                                    <% } else if (log.status === 'error') { %>
                                        <div class="d-flex flex-column align-items-center">
                                            <span class="d-inline-flex align-items-center gap-1 text-danger fw-bold" style="font-size: 11px;">
                                                <i class="ti ti-alert-circle-filled"></i> FAILED
                                            </span>
                                            <% if (log.errorMessage) { %>
                                                <small class="text-danger opacity-75 mt-1" style="font-size: 10px;"><%= log.errorMessage.substring(0, 20) %>...</small>
                                            <% } %>
                                        </div>
                                    <% } else { %>
                                        <span class="d-inline-flex align-items-center gap-1 text-warning fw-bold" style="font-size: 11px;">
                                            <i class="ti ti-clock"></i> WAITING
                                        </span>
                                    <% } %>
                                </td>
                                <td class="px-4 py-3 text-end text-muted opacity-75"><%= new Date(log.createdAt).toLocaleString([], {hour: '2-digit', minute:'2-digit', day:'2-digit', month:'2-digit'}) %></td>
                            </tr>
                            <% }) %>
                            <% if (logs.length === 0) { %>
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted small">No incoming webhook activity found.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <% if (totalPages > 1) { %>
            <div class="card-footer bg-white border-top py-3 px-4">
                <nav class="d-flex justify-content-between align-items-center">
                    <span class="text-muted small">Total: <%= totalLogs %> Records</span>
                    <ul class="pagination pagination-sm mb-0 gap-1 mt-0">
                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                            <a class="page-link border shadow-none rounded-pill" href="/webhooks-logs?page=<%= currentPage - 1 %>&userId=<%= typeof userId !== 'undefined' ? userId : '' %>">
                                <i class="ti ti-chevron-left"></i>
                            </a>
                        </li>
                        <li class="page-item active"><span class="page-link border shadow-none rounded-pill bg-primary text-white border-primary"><%= currentPage %></span></li>
                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link border shadow-none rounded-pill" href="/webhooks-logs?page=<%= currentPage + 1 %>&userId=<%= typeof userId !== 'undefined' ? userId : '' %>">
                                <i class="ti ti-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
            <% } %>
        </div>
    </div>
</div>

<style>
    .bg-soft-primary { background-color: #e8f0fe; }
    .bg-soft-warning { background-color: #fef7e0; }
    .transition-all { transition: all 0.2s ease; }
    .transition-all:hover { background-color: #f8f9fa !important; transform: translateY(-1px); }
    .border-start-4 { border-left-width: 4px !important; }
</style>

<!-- Webhook Details Modal -->
<div class="modal fade" id="webhookDetailsModal" tabindex="-1" aria-labelledby="webhookDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 12px; overflow: hidden;">
            <div class="modal-header bg-white border-bottom-0 pt-4 px-4 pb-2">
                <div>
                    <h5 class="modal-title fw-bold text-dark" id="webhookDetailsModalLabel">Webhook Payload Data</h5>
                    <p class="text-muted small mb-0">Source: <span id="modalSource" class="text-primary fw-medium"></span> &bull; Received at <span id="modalTime" class="fw-medium text-dark"></span></p>
                </div>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="position-relative">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="badge bg-light text-dark border text-uppercase" style="font-size: 10px; letter-spacing: 0.5px;">Raw Body JSON</span>
                        <button class="btn btn-sm btn-light border-0 py-1 px-2 rounded-2" onclick="copyModalContent('modalPayload')" title="Copy JSON">
                            <i class="ti ti-copy me-1"></i> Copy
                        </button>
                    </div>
                    <div class="rounded-3 border overflow-hidden shadow-sm" style="background: #1e1e1e;">
                        <pre id="modalPayload" class="mb-0 p-3 text-success" style="max-height: 500px; overflow-y: auto; font-size: 12px; font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace; line-height: 1.6; color: #9cdcfe !important;"></pre>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top-0 pb-4 px-4 pt-0">
                <button type="button" class="btn btn-primary rounded-pill px-5 fw-bold" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const rows = document.querySelectorAll('.webhook-row');
        const modalElement = document.getElementById('webhookDetailsModal');
        const modal = new bootstrap.Modal(modalElement);
        
        const modalPayload = document.getElementById('modalPayload');
        const modalSource = document.getElementById('modalSource');
        const modalTime = document.getElementById('modalTime');

        rows.forEach(row => {
            row.addEventListener('click', function(e) {
                if (e.target.closest('button') || e.target.closest('a')) return;

                const payload = JSON.parse(this.getAttribute('data-payload') || '{}');
                const source = this.getAttribute('data-source');
                const time = this.getAttribute('data-time');

                modalPayload.textContent = JSON.stringify(payload, null, 4);
                modalSource.textContent = source;
                modalTime.textContent = time;
                
                modal.show();
            });
        });
    });

    async function copyModalContent(elementId) {
        const text = document.getElementById(elementId).textContent;
        try {
            await navigator.clipboard.writeText(text);
            const btn = event.currentTarget;
            const originalHTML = btn.innerHTML;
            btn.innerHTML = '<i class="ti ti-check text-success"></i> Copied!';
            setTimeout(() => btn.innerHTML = originalHTML, 2000);
        } catch (err) {
            console.error('Failed to copy: ', err);
        }
    }
</script>
