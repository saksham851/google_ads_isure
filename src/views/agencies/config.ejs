<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card mt-3">
            <div class="card-header">
                <h5 class="mb-1">Add Sub-Account Manually</h5>
                <p class="text-muted mb-0" style="font-size:13px;">
                    Use this only if you need to pre-register a sub-account before the GHL OAuth flow.
                    In most cases, just click <strong>"Connect with GoHighLevel"</strong> on the agencies list — it handles everything automatically.
                </p>
            </div>
            <div class="card-body">
                <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
                <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
                    <i class="ti ti-alert-circle"></i> <%= error %>
                </div>
                <% } %>

                <form action="/agencies" method="POST">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Agency / Sub-Account Name</label>
                            <input type="text" class="form-control" name="agencyName"
                                   placeholder="e.g., Isuremedia - Main" required>
                            <small class="text-muted">A friendly name shown in your dashboard.</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">GHL Agency ID</label>
                            <input type="text" class="form-control" name="agencyId"
                                   placeholder="e.g., 69aad8e0fabd7b425927d40e" required>
                            <small class="text-muted">Found in GHL Agency Settings.</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">GHL Location ID <span class="text-muted fw-normal">(optional)</span></label>
                            <input type="text" class="form-control" name="locationId"
                                   placeholder="e.g., abc123locationid">
                            <small class="text-muted">The sub-account location ID from GHL.</small>
                        </div>
                        <div class="col-12 d-flex gap-2 justify-content-end mt-3">
                            <a href="/agencies" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary d-inline-flex align-items-center gap-2">
                                <i class="ti ti-device-floppy"></i> Save Sub-Account
                            </button>
                        </div>
                    </div>
                </form>

                <hr class="my-4">

                <div class="text-center">
                    <p class="text-muted mb-3" style="font-size:13px;">Or, let GHL handle the account setup automatically:</p>
                    <a href="/auth/install" class="btn btn-outline-primary d-inline-flex align-items-center gap-2">
                        <i class="ti ti-brand-hipchat"></i> Connect with GoHighLevel (Recommended)
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
