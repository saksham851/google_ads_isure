<div class="row g-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm" style="border-radius: 16px; background: #fff;">
            <div class="card-header bg-white py-4 px-4 border-0 d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="mb-1 fw-bold text-dark">Platform Users</h5>
                    <p class="text-muted small mb-0">Total visibility and granular audit controls over all registered agents.</p>
                </div>
                <form action="/users" method="GET" class="d-flex gap-3 align-items-center">
                    <div class="input-group input-group-sm border rounded-pill overflow-hidden px-3 bg-light" style="width: 280px; height: 38px;">
                        <span class="input-group-text bg-transparent border-0"><i class="ti ti-search text-muted"></i></span>
                        <input type="text" name="search" class="form-control bg-transparent border-0 shadow-none" placeholder="Search by email..." value="<%= search %>">
                    </div>
                    <% if (search) { %>
                        <a href="/users" class="btn btn-light btn-sm rounded-pill px-3 fw-bold border" style="height: 38px; display: flex; align-items: center;">
                            <i class="ti ti-rotate-clockwise me-1"></i> Clear
                        </a>
                    <% } %>
                    <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold shadow-sm" style="height: 38px;">Filter</button>
                </form>
            </div>
            
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" style="border-collapse: separate; border-spacing: 0;">
                        <thead class="bg-light">
                            <tr>
                                <th class="px-4 py-3 border-0 small text-uppercase fw-bold text-muted" style="letter-spacing: 1px; font-size: 10px;">User Identity</th>
                                <th class="py-3 border-0 small text-uppercase fw-bold text-muted" style="letter-spacing: 1px; font-size: 10px;">Access Role</th>
                                <th class="py-3 border-0 small text-uppercase fw-bold text-muted text-center" style="letter-spacing: 1px; font-size: 10px;">Managed Sub-Accounts</th>
                                <th class="py-3 border-0 small text-uppercase fw-bold text-muted" style="letter-spacing: 1px; font-size: 10px;">Registration</th>
                                <th class="py-3 px-4 border-0 text-end small text-uppercase fw-bold text-muted" style="letter-spacing: 1px; font-size: 10px;">Audit Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (users && users.length > 0) { %>
                                <% users.forEach(u => { %>
                                    <tr class="user-row">
                                        <td class="px-4 py-3">
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="avatar-circle <%= u.role === 'superadmin' ? 'bg-soft-primary' : 'bg-soft-secondary' %>">
                                                    <%= u.email.substring(0, 1).toUpperCase() %>
                                                </div>
                                                <div>
                                                    <span class="d-block fw-bold text-dark" style="font-size: 14px;"><%= u.email %></span>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge border py-1 px-3 rounded-pill fw-bold <%= u.role === 'superadmin' ? 'bg-soft-primary text-primary' : 'bg-soft-secondary text-secondary' %>" style="font-size: 10px; letter-spacing: 0.5px;">
                                                <i class="ti ti-shield-check me-1"></i><%= u.role.toUpperCase() %>
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex align-items-center justify-content-center gap-2 mb-1">
                                                <span class="badge bg-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 20px; height: 20px; font-size: 10px;">
                                                    <%= u.agencyCount %>
                                                </span>
                                                <small class="text-muted fw-bold" style="font-size: 11px;">Accounts</small>
                                            </div>
                                            <div class="d-flex flex-wrap justify-content-center gap-1">
                                                <% if (u.agencyListData && u.agencyListData.length > 0) { %>
                                                    <% u.agencyListData.slice(0, 3).forEach(item => { %>
                                                        <a href="/logs?locationId=<%= item.locationId %>" class="account-chip">
                                                            <%= item.name %> <span style="font-size: 8.5px; opacity: 0.6; font-weight: normal;">(<%= item.locationId %>)</span>
                                                        </a>
                                                    <% }) %>
                                                    <% if (u.agencyListData.length > 3) { %>
                                                        <span class="account-chip text-muted">+<%= u.agencyListData.length - 3 %></span>
                                                    <% } %>
                                                <% } %>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex flex-column">
                                                <span class="text-dark fw-medium" style="font-size: 13px;"><%= new Date(u.createdAt).toLocaleDateString() %></span>
                                                <small class="text-muted" style="font-size: 11px;"><%= new Date(u.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></small>
                                            </div>
                                        </td>
                                        <td class="px-4 text-end">
                                            <div class="dropdown">
                                                <button class="btn btn-white btn-sm rounded-pill px-3 border shadow-sm dropdown-toggle d-inline-flex align-items-center gap-2" 
                                                        type="button" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 12px; font-weight: 600;">
                                                    <i class="ti ti-shield-search text-primary"></i> Audit Activity
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 p-2 mt-2" style="border-radius: 12px; min-width: 210px;">
                                                    <li><h6 class="dropdown-header small text-uppercase fw-bold text-muted mb-1" style="font-size: 9px; letter-spacing: 1px;">Live Monitoring</h6></li>
                                                    <li>
                                                        <a class="dropdown-item rounded-2 py-2 d-flex align-items-center gap-3" href="/logs?userId=<%= u._id %>">
                                                            <div class="bg-soft-primary p-2 rounded-circle"><i class="ti ti-chart-dots text-primary h6 mb-0"></i></div>
                                                            <div>
                                                                <span class="d-block fw-bold" style="font-size: 13px;">Conversion Logs</span>
                                                                <small class="text-muted" style="font-size: 10px;">Offline data history</small>
                                                            </div>
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a class="dropdown-item rounded-2 py-2 d-flex align-items-center gap-3" href="/webhooks-logs?userId=<%= u._id %>">
                                                            <div class="bg-soft-warning p-2 rounded-circle shadow-sm"><i class="ti ti-plug text-warning h6 mb-0"></i></div>
                                                            <div>
                                                                <span class="d-block fw-bold text-dark" style="font-size: 13px;">Webhook Stream</span>
                                                                <small class="text-muted" style="font-size: 10px;">Real-time event sync</small>
                                                            </div>
                                                        </a>
                                                    </li>
                                                    <li><hr class="dropdown-divider opacity-50"></li>
                                                    <li>
                                                        <a class="dropdown-item rounded-2 py-2 d-flex align-items-center gap-3" href="/users/<%= u._id %>">
                                                            <div class="bg-light p-2 rounded-circle shadow-sm"><i class="ti ti-user text-primary h6 mb-0"></i></div>
                                                            <div>
                                                                <span class="d-block fw-bold text-dark" style="font-size: 13px;">Account Profile</span>
                                                                <small class="text-muted" style="font-size: 10px;">Full user audit details</small>
                                                            </div>
                                                        </a>
                                                    </li>
                                                </ul>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="5" class="text-center py-5 text-muted">No platform users detected.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
            
            <% if (totalPages > 1) { %>
            <div class="card-footer bg-white border-0 py-4 px-4 d-flex justify-content-between align-items-center">
                <div class="small fw-medium text-muted">Page <%= currentPage %> / <%= totalPages %></div>
                <nav>
                    <ul class="pagination pagination-sm mb-0 gap-2">
                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                            <a class="page-link border rounded-circle d-flex align-items-center justify-content-center" style="width: 34px; height: 34px;" href="/users?page=<%= currentPage - 1 %>">
                                <i class="ti ti-chevron-left"></i>
                            </a>
                        </li>
                        <% for(let i=1; i<=totalPages; i++) { %>
                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                <a class="page-link border rounded-circle d-flex align-items-center justify-content-center <%= currentPage === i ? 'bg-primary text-white border-primary' : '' %>" style="width: 34px; height: 34px;" href="/users?page=<%= i %>"><%= i %></a>
                            </li>
                        <% } %>
                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link border rounded-circle d-flex align-items-center justify-content-center" style="width: 34px; height: 34px;" href="/users?page=<%= currentPage + 1 %>">
                                <i class="ti ti-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
            <% } %>
        </div>
    </div>
</div>

<style>
    .bg-soft-primary { background: #e8f0fe; color: #1a73e8; }
    .bg-soft-secondary { background: #f1f3f4; color: #5f6368; }
    
    .avatar-circle {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 16px;
    }

    .user-row {
        transition: background 0.2s ease;
    }
    .user-row:hover {
        background: #fcfcfc !important;
    }

    .account-chip {
        display: inline-block;
        padding: 2px 8px;
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 6px;
        font-size: 10px;
        font-weight: 600;
        color: #5f6368;
        text-decoration: none;
        transition: all 0.2s ease;
    }
    .account-chip:hover {
        background: #e8f0fe;
        color: #1a73e8;
        border-color: #1a73e8;
        transform: translateY(-1px);
    }

    .btn-white { background: #fff; color: #3c4043; }
    .btn-white:hover { background: #f8f9fa; color: #1a73e8; }

    /* Force Table High Density */
    .table > :not(caption) > * > * {
        padding: 1rem 0.5rem;
    }
    
    /* Remove Internal Scrollbars */
    .table-responsive {
        overflow: visible !important;
    }
</style>
