<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%= typeof title !=='undefined' ? title : 'Dashboard' %> | Google Ads Portal
    </title>

    <!-- Favicon -->
    <link rel="icon" type="image/webp" href="<%= baseUrl %>/assets/images/isuremedia-logo.webp">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

    <!-- [Template CSS Files] -->
    <link rel="stylesheet" href="/assets/fonts/tabler-icons.min.css">
    <link rel="stylesheet" href="/assets/fonts/feather.css">
    <link rel="stylesheet" href="/assets/fonts/fontawesome.css">
    <link rel="stylesheet" href="/assets/fonts/material.css">
    <link rel="stylesheet" href="/assets/css/style.css" id="main-style-link">
    <link rel="stylesheet" href="/assets/css/style-preset.css">

    <style>
        :root {
            --bs-primary: #1a73e8; /* Google Blue */
            --bs-primary-rgb: 26, 115, 232;
            --primary: #1a73e8;
            --pc-primary: #1a73e8 !important;
            --pc-primary-hover: #1765cc !important;
            
            --bs-success: #1e8e3e; /* Google Green */
            --bs-danger: #d93025; /* Google Red */
            --bs-warning: #f9ab00; /* Google Yellow */
        }

        body {
            background-color: #f8f9fa !important;
            font-family: 'Public Sans', 'Roboto', sans-serif;
            color: #3c4043;
        }

        .btn-primary {
            background-color: var(--bs-primary) !important;
            border-color: var(--bs-primary) !important;
            border-radius: 4px !important;
            font-weight: 500;
            padding: 8px 24px;
            box-shadow: none !important;
            transition: all 0.2s ease;
        }

        .btn-primary:hover {
            background-color: var(--pc-primary-hover) !important;
            box-shadow: 0 1px 2px 0 rgba(60,64,67,0.302), 0 1px 3px 1px rgba(60,64,67,0.149) !important;
        }

        /* Sidebar Styling - Google Ads Style */
        .pc-sidebar {
            background: #ffffff !important;
            border-right: 1px solid #dadce0 !important;
            box-shadow: none !important;
        }

        .pc-sidebar .pc-link {
            color: #5f6368 !important;
            font-weight: 500;
            padding: 12px 24px !important;
            border-radius: 0 25px 25px 0 !important;
            margin-right: 10px;
        }

        .pc-sidebar .pc-link:hover {
            background: #f1f3f4 !important;
            color: #1a73e8 !important;
        }

        .pc-sidebar .pc-item.active > .pc-link {
            color: var(--bs-primary) !important;
            background: #e8f0fe !important;
            position: relative;
        }

        .pc-sidebar .pc-item.active > .pc-link::before {
            content: "";
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            background: var(--bs-primary);
            border-radius: 0 2px 2px 0;
        }

        .pc-sidebar .pc-item.active > .pc-link::after {
            display: none !important;
        }

        .pc-sidebar .pc-item.active .pc-micon {
            color: var(--bs-primary) !important;
        }

        .pc-micon {
            color: #5f6368;
            margin-right: 12px;
        }

        .pc-sidebar .pc-caption {
            color: #70757a !important;
            font-size: 11px !important;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            padding: 24px 24px 8px !important;
            font-weight: 700 !important;
        }

        /* Card Styling */
        .card {
            border: 1px solid #dadce0 !important;
            border-radius: 8px !important;
            box-shadow: none !important;
            transition: box-shadow 0.2s ease;
        }

        .card:hover {
            box-shadow: 0 1px 2px 0 rgba(60,64,67,0.302), 0 1px 3px 1px rgba(60,64,67,0.149) !important;
        }

        .card-header {
            background-color: transparent !important;
            border-bottom: 1px solid #dadce0 !important;
            padding: 16px 20px !important;
        }

        /* Header Styling */
        .pc-header {
            background: #ffffff !important;
            border-bottom: 1px solid #dadce0 !important;
            box-shadow: none !important;
            height: 64px !important;
        }

        .pc-header .pc-head-link {
            color: #5f6368 !important;
        }

        /* Breadcrumb */
        .breadcrumb {
            background: transparent !important;
            padding: 0 !important;
            margin-bottom: 24px !important;
        }

        .breadcrumb-item a {
            color: #5f6368 !important;
            text-decoration: none !important;
        }

        .breadcrumb-item.active {
            color: #3c4043 !important;
            font-weight: 500 !important;
        }

        /* Container padding */
        .pc-container {
            padding-top: 20px !important;
        }
    </style>
</head>

<body data-pc-preset="preset-1" data-pc-sidebar-caption="true" data-pc-layout="vertical" data-pc-direction="ltr"
    data-pc-theme="light">

    <%- include('../partials/sidebar') %>
        <%- include('../partials/header') %>

            <div class="pc-container">
                <div class="pc-content">
                    <!-- Breadcrumb -->
                    <div class="page-header">
                        <div class="page-block">
                            <div class="row align-items-center">
                                <div class="col-md-12">
                                    <ul class="breadcrumb">
                                        <li class="breadcrumb-item"><a href="/dashboard">Home</a></li>
                                        <li class="breadcrumb-item">
                                            <%= typeof title !=='undefined' ? title : 'Dashboard' %>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>

                    <%- body %>
                </div>
            </div>

            <!-- Required Js -->
            <script src="/assets/js/plugins/popper.min.js"></script>
            <script src="/assets/js/plugins/simplebar.min.js"></script>
            <script src="/assets/js/plugins/bootstrap.min.js"></script>
            <script src="/assets/js/fonts/custom-font.js"></script>
            <script src="/assets/js/pcoded.js"></script>
            <script src="/assets/js/plugins/feather.min.js"></script>

            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script>
                feather.replace();
                layout_change('light');
                preset_change("preset-1");
                font_change("Public-Sans");
            </script>
</body>

</html>