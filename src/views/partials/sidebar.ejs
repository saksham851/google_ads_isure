<style>
    .pc-sidebar .pc-item .pc-link {
        border-radius: 8px !important;
        margin: 4px 16px !important;
        transition: all 0.2s ease-in-out;
    }
</style>
<nav class="pc-sidebar">
    <div class="navbar-wrapper">
        <div class="m-header justify-content-center">
            <a href="/dashboard" class="b-brand">
                <img src="/assets/images/isuremedia-logo.webp" class="img-fluid logo-lg" alt="SURE Media" style="max-height: 55px;">
            </a>
        </div>
        <div class="navbar-content">
            <ul class="pc-navbar mt-3">

                <li class="pc-item pc-caption">
                    <label class="fw-bold text-uppercase small" style="letter-spacing: 1px; color: #94a3b8;">Main
                        Navigation</label>
                    <i class="ti ti-settings"></i>
                </li>

                <li
                    class="pc-item <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
                    <a href="/dashboard<%= activeLocationId ? '?locationId=' + activeLocationId : '' %>" class="pc-link">
                        <span class="pc-micon"><i class="ti ti-dashboard"></i></span>
                        <span class="pc-mtext">Dashboard</span>
                    </a>
                </li>

                <% if (user && user.role === 'superadmin') { %>
                <li
                    class="pc-item <%= typeof activePage !== 'undefined' && activePage === 'users' ? 'active' : '' %>">
                    <a href="/users" class="pc-link">
                        <span class="pc-micon"><i class="ti ti-users"></i></span>
                        <span class="pc-mtext">Users</span>
                    </a>
                </li>
                <% } %>

                <li class="pc-item pc-caption">
                    <label class="fw-bold text-uppercase small"
                        style="letter-spacing: 1px; color: #94a3b8;">Integrations</label>
                    <i class="ti ti-link"></i>
                </li>

                <li
                    class="pc-item <%= typeof activePage !== 'undefined' && activePage === 'agencies' ? 'active' : '' %>">
                    <a href="/agencies<%= activeLocationId ? '?locationId=' + activeLocationId : '' %>" class="pc-link">
                        <span class="pc-micon"><i class="ti ti-building"></i></span>
                        <span class="pc-mtext">Sub-Accounts</span>
                    </a>
                </li>

                <li class="pc-item pc-caption">
                    <label class="fw-bold text-uppercase small"
                        style="letter-spacing: 1px; color: #94a3b8;">Monitoring</label>
                    <i class="ti ti-activity"></i>
                </li>

                <li class="pc-item <%= typeof activePage !== 'undefined' && activePage === 'logs' ? 'active' : '' %>">
                    <a href="/logs<%= activeLocationId ? '?locationId=' + activeLocationId : '' %>" class="pc-link">
                        <span class="pc-micon"><i class="ti ti-file-text"></i></span>
                        <span class="pc-mtext">Conversion Logs</span>
                    </a>
                </li>

                <li
                    class="pc-item <%= typeof activePage !== 'undefined' && activePage === 'webhooks' ? 'active' : '' %>">
                    <a href="/webhooks-logs<%= activeLocationId ? '?locationId=' + activeLocationId : '' %>" class="pc-link">
                        <span class="pc-micon"><i class="ti ti-plug"></i></span>
                        <span class="pc-mtext">Webhook Logs</span>
                    </a>
                </li>

            </ul>
        </div>
    </div>
</nav>