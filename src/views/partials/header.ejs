<header class="pc-header">
  <div class="header-wrapper">
    <!-- [Mobile Media Block] start -->
    <div class="me-auto pc-mob-drp">
      <ul class="list-unstyled">
        <li class="pc-h-item pc-sidebar-collapse">
          <a href="#" class="pc-head-link ms-0" id="sidebar-hide">
            <i class="ti ti-menu-2"></i>
          </a>
        </li>
        <li class="pc-h-item pc-sidebar-popup">
          <a href="#" class="pc-head-link ms-0" id="mobile-collapse">
            <i class="ti ti-menu-2"></i>
          </a>
        </li>
      </ul>
    </div>
    <!-- [Mobile Media Block end] -->
    <div class="ms-auto">
      <ul class="list-unstyled d-flex align-items-center mb-0">
        <li class="dropdown pc-h-item header-user-profile me-3">
          <% if (user && user.role === 'ghl_user') { %>
            <!-- Sub-account users see a simple label, no dropdown/logout -->
            <div class="d-flex align-items-center py-2">
              <img src="https://ui-avatars.com/api/?name=GHL&background=1a73e8&color=fff" alt="user-image"
                class="user-avtar wid-35 me-2 rounded-circle">
              <span class="d-none d-sm-inline-block fw-semibold text-dark">
                Sub-account
              </span>
            </div>
          <% } else { %>
            <!-- Superadmins see the full dropdown with logout -->
            <a class="dropdown-toggle text-decoration-none arrow-none"
              style="box-shadow: none !important; cursor: pointer; display: flex; align-items: center;"
              data-bs-toggle="dropdown" href="#" role="button"
              data-bs-auto-close="outside" aria-expanded="false">
              <div class="d-flex align-items-center">
                <img src="https://ui-avatars.com/api/?name=Admin&background=1a73e8&color=fff" alt="user-image"
                  class="user-avtar wid-35 me-2 rounded-circle">
                <span class="d-none d-sm-inline-block fw-semibold text-dark">
                  <%= user ? user.email.split('@')[0] : 'Admin' %>
                </span>
              </div>
            </a>
            <div class="dropdown-menu dropdown-user-profile dropdown-menu-end pc-h-dropdown">
              <div class="dropdown-header" style="padding: 12px 16px;">
                <h6 class="mb-0 fw-semibold text-dark" style="font-size: 14px;">
                  <%= user ? user.email : 'Administrator' %>
                </h6>
                <span class="small" style="color: #1a73e8; text-transform: capitalize; font-weight: 500;">
                  <%= user ? user.role : 'Admin' %>
                </span>
              </div>
              <hr class="dropdown-divider my-1">
              <div class="d-grid px-3 pb-3 mt-2">
                <a href="/superadmin/logout" class="btn btn-sm"
                  style="background:#f1f3f4; color:#3c4043; border:1px solid #dadce0; font-weight:500; border-radius:6px;">
                  <i class="ti ti-power me-1"></i>Logout
                </a>
              </div>
            </div>
          <% } %>
        </li>
      </ul>
    </div>
  </div>
</header>